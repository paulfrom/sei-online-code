{
  "name": "sei-online-code-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "analyze": "cross-env ANALYZE=1 umi build",
    "build": "cross-env ESLINT=none umi build",
    "test:regression": "node --test tests/requirement-workspace-regression.test.cjs",
    "lint": "npm run lint:script && npm run lint:style",
    "lint-fix": "npm run lint-fix:script && npm run lint-fix:style",
    "lint-fix:script": "npm run lint:script --fix",
    "lint-fix:style": "npm run lint:style --fix",
    "lint:script": "eslint --ext '.js,.jsx,.ts,.tsx'",
    "lint:style": "stylelint 'src/**/*.less' --allow-empty-input",
    "precommit": "lint-staged --allow-empty",
    "prepare": "husky",
    "prettier": "prettier -c --write '**/*'",
    "start": "cross-env MOCK=none umi dev"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,css,less}": [
      "umi lint --fix --allow-empty"
    ],
    "**/*.{js,jsx,tsx,ts,less,md,json}": [
      "prettier --write",
      "git add"
    ]
  },
  "resolutions": {
    "chevrotain": "11.0.0"
  },
  "dependencies": {
    "@ant-design/colors": "^8.0.1",
    "@ant-design/cssinjs": "^2.1.2",
    "@ant-design/cssinjs-utils": "^2.1.2",
    "@ant-design/fast-color": "^3.0.1",
    "@ant-design/react-slick": "~2.0.0",
    "@babel/runtime": "^7.28.4",
    "@datasert/cronjs-matcher": "^1.4.0",
    "@ead/antd-style": "^4.1.0-2",
    "@ead/suid": "^2.1.49",
    "@ead/suid-icons": "^1.2.5",
    "@ead/suid-utils-react": "^1.0.91",
    "@tailwindcss/postcss": "^4.3.0",
    "@umijs/plugins": "^4.6.53",
    "ahooks": "^3.8.4",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "lodash": "^4.18.1",
    "lodash-es": "^4.17.21",
    "quill": "^1.3.7",
    "react": "^18",
    "react-markdown": "^10.0.0",
    "remark-gfm": "^4.0.0",
    "react-activation": "^0.12.4",
    "react-dom": "^18",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@ead/babel-plugin-suid-import": "^2.0.22",
    "@types/node": "^24.2.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/parser": "^8.11.0",
    "@umijs/lint": "4.3.31",
    "cross-env": "^6.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.0.1",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.7",
    "msw": "^2.14.6",
    "prettier": "^3.3.2",
    "stylelint": "14.x",
    "typescript": "^5.6.3",
    "umi": "^4.6.53",
    "umi-plugin-keep-alive": "0.0.1-beta.35"
  },
  "optionalDependencies": {
    "less-vars-to-js": "^1.3.0"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "chevrotain": "11.0.0"
  },
  "title": "sei-online-code-web",
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
